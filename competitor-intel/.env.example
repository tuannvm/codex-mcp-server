# Competitor Intelligence - Environment Configuration
# Copy this file to .env and fill in your values

# Server port (default: 3456)
PORT=3456

# Email alerts for negative articles about The Dobbs Group
# Set all SMTP values to enable email alerts
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-app-password
ALERT_FROM=alerts@yourdomain.com
ALERT_TO=craig.dobbs@morganstanley.com

# Dashboard authentication
DASHBOARD_PASSWORD=your-secure-password
AUTH_SECRET=your-random-32-char-secret-here

# Financial data APIs
FRED_API_KEY=your-fred-api-key
ALPHA_VANTAGE_KEY=your-alpha-vantage-key
FINRA_API_KEY=your-finra-api-key
